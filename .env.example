# Copy this file to `.env` and adjust as needed:  cp .env.example .env
#
# These URLs match the local Prisma Postgres dev server started by
# `bun --bun run prisma dev` (ports 51214 / 51215 with default settings).

# Main database connection used by the app and by `prisma migrate`.
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0"

# Shadow database used by `prisma migrate dev` to detect schema drift.
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:51215/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0"

# Optional: port the Problem 5 API listens on (defaults to 8000).
# PORT=8000
