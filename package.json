{
  "name": "code-challenge",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "problem4": "bun run ./src/problem4/index.ts",
    "test:problem4": "bun test ./src/problem4/sum_to_n.test.ts",

    "db:setup": "bun run db:migrate:deploy && bun run db:generate",
    "preproblem5": "bun run db:setup",
    "problem5": "bun run ./src/problem5/src/index.ts",
    "preproblem5:dev": "bun run db:setup",
    "problem5:dev": "bun run --watch ./src/problem5/src/index.ts",

    "db:generate": "bunx prisma generate --schema=./src/problem5/prisma/schema.prisma",
    "db:migrate": "bunx prisma migrate dev --schema=./src/problem5/prisma/schema.prisma",
    "db:migrate:deploy": "bunx prisma migrate deploy --schema=./src/problem5/prisma/schema.prisma",
    "db:migrate:reset": "bunx prisma migrate reset --schema=./src/problem5/prisma/schema.prisma",

    "db:migrate:test": "DATABASE_URL=\"postgres://postgres:postgres@localhost:51214/template1?sslmode=disable&schema=test\" bun --bun run prisma migrate deploy --schema=./src/problem5/prisma/schema.prisma",

    "pretest:problem5": "bun run db:migrate:test",
    "test:problem5": "bun test ./src/problem5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3",
    "zod-openapi": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
